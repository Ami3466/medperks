# Copy to .env and fill in. EXPO_PUBLIC_ vars are bundled into the client.

# Optional self-hosted API sync/AI verification endpoint.
EXPO_PUBLIC_API_URL=https://api.your-domain.com

# Server-side only. NEVER prefix these with EXPO_PUBLIC.
# Put these in the API service or Coolify secrets. They must not be bundled
# into the client app.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
STRIPE_SECRET_KEY=sk_live_OR_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# EAS / store builds (CI-only). Add as GitHub Actions secrets on the repo,
# then run the "EAS Mobile Build" workflow. Not read by the app at runtime.
#   EXPO_TOKEN        - create at https://expo.dev/settings/access-tokens
#   EXPO_PUBLIC_API_URL  - backend URL baked into the build (blank = local-only)
EXPO_TOKEN=
